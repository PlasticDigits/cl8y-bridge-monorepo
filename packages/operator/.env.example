# CL8Y Bridge Relayer Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Database
# =============================================================================
# Matches docker-compose postgres service (operator / operator DB on host port 5433)
DATABASE_URL=postgres://operator:operator@localhost:5433/operator

# =============================================================================
# EVM Chain Configuration (Anvil local)
# =============================================================================
EVM_RPC_URL=http://localhost:8545
EVM_CHAIN_ID=31337
# Deployed via: forge script script/DeployLocal.s.sol:DeployLocal --broadcast --rpc-url http://localhost:8545
EVM_BRIDGE_ADDRESS=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707
# Router not deployed in minimal local setup - use bridge address as placeholder
EVM_ROUTER_ADDRESS=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707
# Anvil default account 0 private key
EVM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# =============================================================================
# Terra Classic Configuration (LocalTerra)
# =============================================================================
TERRA_RPC_URL=http://localhost:26657
TERRA_LCD_URL=http://localhost:1317
TERRA_CHAIN_ID=localterra
TERRA_BRIDGE_ADDRESS=terra1...
# LocalTerra test mnemonic (DO NOT use in production!)
TERRA_MNEMONIC="notice oak worry limit wrap speak medal online prefer cluster roof addict wrist behave treat actual wasp year salad speed social layer crew genius"

# =============================================================================
# Solana Configuration (Local Validator)
# =============================================================================
# Comma-separated JSON-RPC URLs, tried in order (same pattern as EVM_RPC_URL). Alias: SOLANA_MAINNET_RPC.
SOLANA_RPC_URL=http://localhost:8899
# SOLANA_MAINNET_RPC=https://a.example,b.example
SOLANA_WS_URL=ws://localhost:8900
# Deployed via: anchor deploy --provider.cluster localnet
SOLANA_PROGRAM_ID=<program_id_from_deploy>
# Local validator keypair (DO NOT use in production!)
# Base58, JSON [u8,…] keypair, 0x + 128 hex (full keypair), or 64 hex chars (32-byte seed)
SOLANA_PRIVATE_KEY=<base58_or_json_or_hex>
# QA only (`make start-qa`): comma-separated pubkeys to fund on localnet (see scripts/solana/airdrop-qa-wallets.sh)
# SOLANA_QA_AIRDROP_WALLETS=Pubkey1,Pubkey2
# SOLANA_QA_AIRDROP_SOL=100
# SOLANA_QA_AIRDROP_CHUNK_SOL=2
# SOLANA_QA_AIRDROP_SLEEP_MS=1000
# SOLANA_QA_AIRDROP_MAX_RETRIES=5
#
# QA only (`make start-qa`): fund browser/extension wallets with native gas on Anvil, Anvil1, LocalTerra (see scripts/qa/fund-qa-gas-wallets.sh)
# EVM_QA_FUND_WALLETS=0x...,0x...          # comma-separated; Anvil (EVM_RPC_URL) + same list on Anvil1 unless EVM1_QA_FUND_WALLETS is set
# EVM1_QA_FUND_WALLETS=0x...               # optional override for second chain only
# EVM_QA_FUND_ETH=50ether
# EVM1_QA_FUND_ETH=50ether
# EVM_QA_FUND_PRIVATE_KEY=               # default: EVM_PRIVATE_KEY (Anvil #0 in QA)
# TERRA_QA_FUND_WALLETS=terra1...,terra1...
# TERRA_QA_FUND_COINS=100000000uluna
# TERRA_KEY_NAME=test1

# =============================================================================
# API Rate Limiting (optional)
# =============================================================================
# RATE_LIMIT_PER_SECOND=10
# RATE_LIMIT_BURST_SIZE=30

# =============================================================================
# Relayer Settings
# =============================================================================
FINALITY_BLOCKS=1
POLL_INTERVAL_MS=1000
RETRY_ATTEMPTS=5
RETRY_DELAY_MS=5000

# =============================================================================
# Fee Configuration
# =============================================================================
DEFAULT_FEE_BPS=30
# Anvil default account 1
FEE_RECIPIENT=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# =============================================================================
# Bounded Cache Configuration (optional — prevents unbounded memory growth)
# =============================================================================
# Max entries in the approved-hashes cache (default: 100000)
# Each entry ≈ 40 bytes → 100k entries ≈ 4 MB
# APPROVED_HASH_CACHE_SIZE=100000
#
# Max entries in the pending-executions cache (default: 50000)
# Each entry ≈ 200 bytes → 50k entries ≈ 10 MB
# PENDING_EXECUTION_CACHE_SIZE=50000
#
# TTL in seconds for cache entries (default: 86400 = 24 hours)
# HASH_CACHE_TTL_SECS=86400
#
# Recommended RAM: 512 MB minimum for defaults, scale linearly for larger caches.
