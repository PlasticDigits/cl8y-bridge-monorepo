# CL8Y Bridge Frontend Environment Configuration
# Copy this to .env.local and fill in values

# Set to true to serve only a static under-construction page (all URLs).
# VITE_UNDER_CONSTRUCTION=false

# Network environment: local | testnet | mainnet
VITE_NETWORK=local

# Contract Addresses — See README.md "Live Deployments" for mainnet values
# Local: Run `make deploy` to deploy contracts and get addresses
# Mainnet: terra18m02l2f43c2dagqnz3kfccpgz9pzzz5hk9l5mh5wvr6dcvv47zfqdfs7la (Terra)
#         0xb2a22c74da8e3642e0effc107d3ac362ce885369 (BSC/opBNB Bridge — same address both chains)
#         0xd7b3bf05987052009c350874e810df98da95d258 (LockUnlock)
VITE_TERRA_BRIDGE_ADDRESS=
VITE_EVM_BRIDGE_ADDRESS=
# Legacy single-primary EVM fallback (BSC/opBNB only). MegaETH uses VITE_MEGAETH_* — see docs/deployment-megaeth.md § Frontend (GL-124).
VITE_EVM_ROUTER_ADDRESS=

# Token Configuration for EVM deposits
# Local: Deploy with forge script script/DeployTestToken.s.sol --broadcast
# Mainnet BSC Test A: 0x3557bfd147b35C2647EAFC05c8BE757ce84D5B1c
# Mainnet BSC Test B: 0x39c4a8d50Cdd20131eC91B3ACcc6352123F68B52
# Mainnet BSC Test Dec: 0xe159c7a58d694fafba82221905d5a49e7f314330
VITE_BRIDGE_TOKEN_ADDRESS=
VITE_LOCK_UNLOCK_ADDRESS=

# RPC URLs (optional — defaults per network in constants.ts)
# Mainnet: https://bsc-dataseed1.binance.org, https://terra-classic-lcd.publicnode.com, etc.
VITE_EVM_RPC_URL=http://localhost:8545
VITE_TERRA_LCD_URL=http://localhost:1317
VITE_TERRA_RPC_URL=http://localhost:26657

# MegaETH mainnet (when `VITE_NETWORK=mainnet`). Vite exposes only `VITE_*`; duplicate operators’ `MEGAETH_*` here for the bundle.
# See docs/deployment-megaeth.md § Frontend (issue GL-124, option A); option B manifest env is tracked on the same issue.
# VITE_MEGAETH_RPC_URL=https://mainnet.megaeth.com/rpc
# VITE_MEGAETH_BRIDGE_ADDRESS=0xb2A22c74dA8E3642e0EffC107d3Ac362ce885369

# WalletConnect Project ID — REQUIRED for production (get from cloud.walletconnect.com)
# Without this, WalletConnect modal will not appear; MetaMask and other extensions still work
VITE_WC_PROJECT_ID=

# Faucet contract addresses (deploy via DeployFaucet.s.sol / CosmWasm, then grant minter role)
VITE_BSC_FAUCET_ADDRESS=
VITE_OPBNB_FAUCET_ADDRESS=
VITE_TERRA_FAUCET_ADDRESS=

# Solana (optional — defaults per VITE_NETWORK in app config)
# Mainnet: program + noneconomic test SPL mints (see README "Solana mainnet-beta" and docs/deployment-solana-mainnet.md)
# Full RPC override (all routes / tiers): comma-separated, tried in order.
# VITE_SOLANA_RPC_URL=https://solana-rpc.publicnode.com/,https://solana-mainnet.gateway.tatum.io/
# (Avoid api.mainnet.solana.com in the browser — often 403; use a CORS-friendly provider.)
# Mainnet/devnet: the app merges these URLs with built-in public fallbacks for every Solana JSON-RPC call.
# Transactions: default uses the bridge RPC list (sign + sendRaw on that Connection). To try the wallet’s
# exposed RPC first (legacy), set either:
#   VITE_SOLANA_TX_USE_BRIDGE_RPC=false
#   VITE_SOLANA_TX_USE_WALLET_RPC=true
# Force bridge-only txs regardless:
#   VITE_SOLANA_TX_USE_BRIDGE_RPC=true
# Prefer wallet signAndSend before sign+sendRaw (rare; debugging):
#   VITE_SOLANA_PREFER_SIGN_AND_SEND_FIRST=true
# Mainnet-only default list (when VITE_SOLANA_RPC_URL unset): same comma-separated shape as SOLANA_MAINNET_RPC on the server.
# VITE_SOLANA_MAINNET_RPC=https://solana-rpc.publicnode.com/,https://solana-mainnet.gateway.tatum.io/
# VITE_SOLANA_PROGRAM_ID=4XX8ndYXupw4Sb4SsRgAPTmBJJjfZbg8rWjj87iKEhVt
# BridgeConfig PDA (mainnet, seeds ["bridge"]): HarAAW2pPcgBwMhcwRsUxRqiDeihCJVjZCmdCWpJbmsD — reference; derived from program id in app
# VITE_SOLANA_TESTA_MINT=6XjWBbRJW5uhd8csCiDivXGPF42yYoyDARtxEtX3oP7E
# VITE_SOLANA_TESTB_MINT=EvAWhkKQzX8om5VDWjg8oEvCw9jhGGKsn3rdrNXmQScX
# VITE_SOLANA_TDEC_MINT=765GMcrKxfevfBhnJmZDhdyHDon2nTwGemcgqJApNBR

# Dev mode: enable simulated EVM and Terra wallets on Connect (no extensions required)
VITE_DEV_MODE=false

# Test Configuration (for integration tests)
SKIP_INTEGRATION=false
