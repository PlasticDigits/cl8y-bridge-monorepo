# CL8Y Bridge Frontend Environment Configuration
# Copy this to .env.local and fill in values

# Network environment: local | testnet | mainnet
VITE_NETWORK=local

# Contract Addresses — See README.md "Live Deployments" for mainnet values
# Local: Run `make deploy` to deploy contracts and get addresses
# Mainnet: terra18m02l2f43c2dagqnz3kfccpgz9pzzz5hk9l5mh5wvr6dcvv47zfqdfs7la (Terra)
#         0xb2a22c74da8e3642e0effc107d3ac362ce885369 (BSC/opBNB Bridge — same address both chains)
#         0xd7b3bf05987052009c350874e810df98da95d258 (LockUnlock)
VITE_TERRA_BRIDGE_ADDRESS=
VITE_EVM_BRIDGE_ADDRESS=
VITE_EVM_ROUTER_ADDRESS=

# Token Configuration for EVM deposits
# Local: Deploy with forge script script/DeployTestToken.s.sol --broadcast
# Mainnet BSC Test A: 0x3557bfd147b35C2647EAFC05c8BE757ce84D5B1c
# Mainnet BSC Test B: 0x39c4a8d50Cdd20131eC91B3ACcc6352123F68B52
# Mainnet BSC Test Dec: 0xe159c7a58d694fafba82221905d5a49e7f314330
VITE_BRIDGE_TOKEN_ADDRESS=
VITE_LOCK_UNLOCK_ADDRESS=

# RPC URLs (optional — defaults per network in constants.ts)
# Mainnet: https://bsc-dataseed1.binance.org, https://terra-classic-lcd.publicnode.com, etc.
VITE_EVM_RPC_URL=http://localhost:8545
VITE_TERRA_LCD_URL=http://localhost:1317
VITE_TERRA_RPC_URL=http://localhost:26657

# WalletConnect Project ID — REQUIRED for production (get from cloud.walletconnect.com)
# Without this, WalletConnect modal will not appear; MetaMask and other extensions still work
VITE_WC_PROJECT_ID=

# Faucet contract addresses (deploy via DeployFaucet.s.sol / CosmWasm, then grant minter role)
VITE_BSC_FAUCET_ADDRESS=
VITE_OPBNB_FAUCET_ADDRESS=
VITE_TERRA_FAUCET_ADDRESS=

# Dev mode: enable simulated EVM and Terra wallets on Connect (no extensions required)
VITE_DEV_MODE=false

# Test Configuration (for integration tests)
SKIP_INTEGRATION=false
