{
  "name": "@cl8y-bridge/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "env:local": "bash ../../scripts/qa/write-frontend-env-local.sh",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src e2e --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "SKIP_INTEGRATION=true vitest run",
    "test:integration": "vitest run src/test/integration.test.ts",
    "test:integration:chains": "vitest run --config vitest.config.integration.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:setup": "tsx src/test/e2e-infra/setup.ts",
    "qa:full-token-setup": "tsx src/test/e2e-infra/qa-full-token-setup.ts",
    "test:e2e:teardown": "tsx src/test/e2e-infra/teardown.ts",
    "test:bridge": "vitest run --config vitest.config.integration.ts src/test/transfers/",
    "test:e2e:verify": "playwright test --project=verification --workers=1",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@goblinhunt/cosmes": "^0.0.71-ghunt.21",
    "@noble/hashes": "^1.5.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.17.0",
    "buffer": "^6.0.3",
    "react": "^18.2.0",
    "react-blockies": "^1.4.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bs58": "^4.0.4",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "happy-dom": "^20.4.0",
    "jsdom": "^28.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "bigint-buffer": "npm:bigint-buffer-fixed@1.1.6",
    "minimatch": "^9.0.9",
    "tar": "^7.5.12",
    "node-gyp": "^12.2.0",
    "@tootallnate/once": "^3.0.1",
    "@cosmjs/amino": "0.34.1",
    "@cosmjs/crypto": "0.34.1",
    "@cosmjs/encoding": "0.34.1",
    "@cosmjs/math": "0.34.1",
    "@cosmjs/proto-signing": "0.34.1",
    "@cosmjs/utils": "0.34.1"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
