#!/bin/bash
# =============================================================================
# CL8Y Bridge Pre-commit Hook
# =============================================================================
# SECURITY: This bridge handles cross-chain assets.
# ALL checks run on EVERY commit. No exceptions. No skipping.
#
# Checks:
#   1. Formatting (Rust + Solidity) - ALL packages
#   2. Clippy linting (Rust) - ALL packages
#   3. Frontend TypeScript type check + ESLint
#   4. Secret detection (gitleaks)
#   5. Full E2E tests (starts infra, runs tests, tears down) [disabled]
#
# Install: git config core.hooksPath .githooks
# Skip: git commit --no-verify (USE THIS, GET FIRED. CRITICAL security risk)
#
# NOTE: This hook runs FULL E2E tests. Commits will take 10-30+ minutes.
# =============================================================================

set -e

# Get the repo root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Track overall success
CHECKS_PASSED=true

echo "============================================================"
echo "  CL8Y Bridge Pre-commit Security Checks"
echo "  ALL checks run on EVERY commit. No skipping."
echo "============================================================"

# ==============================================================================
# FORMATTING CHECKS - ALL PACKAGES, ALWAYS
# ==============================================================================

echo ""
echo "🔧 Checking code formatting (ALL packages)..."

# Operator
if command -v cargo &> /dev/null; then
    echo "  → Checking operator (Rust fmt)..."
    if ! (cd "$REPO_ROOT/packages/operator" && cargo fmt --check 2>/dev/null); then
        echo "❌ Operator has formatting issues. Run: cd packages/operator && cargo fmt"
        CHECKS_PASSED=false
    else
        echo "    ✓ operator formatted"
    fi
fi

# Canceler
if command -v cargo &> /dev/null; then
    echo "  → Checking canceler (Rust fmt)..."
    if ! (cd "$REPO_ROOT/packages/canceler" && cargo fmt --check 2>/dev/null); then
        echo "❌ Canceler has formatting issues. Run: cd packages/canceler && cargo fmt"
        CHECKS_PASSED=false
    else
        echo "    ✓ canceler formatted"
    fi
fi

# Terra contracts
if command -v cargo &> /dev/null; then
    echo "  → Checking Terra contracts (Rust fmt)..."
    if ! (cd "$REPO_ROOT/packages/contracts-terraclassic/bridge" && cargo fmt --check 2>/dev/null); then
        echo "❌ Terra contracts have formatting issues. Run: cd packages/contracts-terraclassic/bridge && cargo fmt"
        CHECKS_PASSED=false
    else
        echo "    ✓ terra contracts formatted"
    fi
fi

# E2E package
if command -v cargo &> /dev/null; then
    echo "  → Checking E2E package (Rust fmt)..."
    if ! (cd "$REPO_ROOT/packages/e2e" && cargo fmt --check 2>/dev/null); then
        echo "❌ E2E package has formatting issues. Run: cd packages/e2e && cargo fmt"
        CHECKS_PASSED=false
    else
        echo "    ✓ e2e package formatted"
    fi
fi

# EVM contracts
if command -v forge &> /dev/null; then
    echo "  → Checking EVM contracts (Solidity fmt)..."
    if ! (cd "$REPO_ROOT/packages/contracts-evm" && forge fmt --check src/ script/ test/ 2>/dev/null); then
        echo "❌ EVM contracts have formatting issues. Run: cd packages/contracts-evm && forge fmt"
        CHECKS_PASSED=false
    else
        echo "    ✓ evm contracts formatted"
    fi
fi

# ==============================================================================
# CLIPPY CHECKS - ALL PACKAGES, ALWAYS
# ==============================================================================

echo ""
echo "🔍 Running clippy (ALL Rust packages)..."

# Operator
if command -v cargo &> /dev/null; then
    echo "  → Checking operator (clippy)..."
    if ! (cd "$REPO_ROOT/packages/operator" && cargo clippy --quiet -- -D warnings 2>&1); then
        echo "❌ Operator has clippy warnings. Run: cd packages/operator && cargo clippy -- -D warnings"
        CHECKS_PASSED=false
    else
        echo "    ✓ operator clippy clean"
    fi
fi

# Canceler
if command -v cargo &> /dev/null; then
    echo "  → Checking canceler (clippy)..."
    if ! (cd "$REPO_ROOT/packages/canceler" && cargo clippy --quiet -- -D warnings 2>&1); then
        echo "❌ Canceler has clippy warnings. Run: cd packages/canceler && cargo clippy -- -D warnings"
        CHECKS_PASSED=false
    else
        echo "    ✓ canceler clippy clean"
    fi
fi

# Terra contracts
if command -v cargo &> /dev/null; then
    echo "  → Checking Terra contracts (clippy)..."
    if ! (cd "$REPO_ROOT/packages/contracts-terraclassic/bridge" && cargo clippy --quiet -- -D warnings 2>&1); then
        echo "❌ Terra contracts have clippy warnings. Run: cd packages/contracts-terraclassic/bridge && cargo clippy -- -D warnings"
        CHECKS_PASSED=false
    else
        echo "    ✓ terra contracts clippy clean"
    fi
fi

# ==============================================================================
# FRONTEND - TypeScript type check
# ==============================================================================

echo ""
echo "📦 Checking frontend (TypeScript)..."

if [ -d "$REPO_ROOT/packages/frontend" ]; then
    if ! (cd "$REPO_ROOT/packages/frontend" && npx tsc --noEmit 2>/dev/null); then
        echo "❌ Frontend has TypeScript errors. Run: cd packages/frontend && npx tsc --noEmit"
        CHECKS_PASSED=false
    else
        echo "    ✓ frontend typecheck clean"
    fi

    echo "  → Running ESLint..."
    if ! (cd "$REPO_ROOT/packages/frontend" && npx eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0 2>/dev/null); then
        echo "❌ Frontend has lint errors. Run: cd packages/frontend && npm run lint"
        CHECKS_PASSED=false
    else
        echo "    ✓ frontend lint clean"
    fi
fi

# ==============================================================================
# SECRET DETECTION
# ==============================================================================

echo ""
echo "🔍 Checking for secrets..."

if ! command -v gitleaks &> /dev/null; then
    echo "⚠️  gitleaks is not installed. Skipping secret detection."
    echo "   Install: brew install gitleaks (macOS) or sudo apt install gitleaks"
else
    if ! gitleaks protect --staged --config .gitleaks.toml --verbose; then
        echo ""
        echo "❌ Gitleaks found potential secrets in your staged changes!"
        CHECKS_PASSED=false
    else
        echo "    ✓ no secrets detected"
    fi
fi

# ==============================================================================
# E2E TESTS - FULL SUITE WITH SETUP AND TEARDOWN (RUST)
# ==============================================================================
# NOTE: Disabled due to time constraints.
# echo ""
# echo "🧪 Running FULL E2E test suite (Rust)..."
# echo "   This includes: infrastructure setup, all tests, teardown"
# echo "   Teardown runs ALWAYS, even on failure"
# echo "   Expected time: 5-15 minutes"
# echo ""

# cd "$REPO_ROOT"
# if ! make e2e-full-rust; then
#     echo ""
#     echo "❌ E2E tests failed!"
#     CHECKS_PASSED=false
# else
#     echo "    ✓ all E2E tests passed"
# fi

# ==============================================================================
# FINAL RESULT
# ==============================================================================

echo ""
echo "============================================================"

if [ "$CHECKS_PASSED" = false ]; then
    echo "❌ PRE-COMMIT CHECKS FAILED"
    echo ""
    echo "Fix the issues above, then stage your changes and try again."
    echo "To skip checks (USE THIS, GET FIRED. CRITICAL security risk): git commit --no-verify"
    echo "============================================================"
    exit 1
fi

echo "✅ ALL PRE-COMMIT CHECKS PASSED"
echo "============================================================"
