# Shared QA host layout: defaults match docker-compose.yml LocalTerra publish ports
# (E2E_TERRA_RPC_PORT→26657, E2E_TERRA_LCD_PORT→1317, gRPC 9090/9091).
#
# If another stack already uses 26657/1317 on this machine, export remapped ports before
# `docker compose up` and set the same values here, e.g. E2E_TERRA_RPC_PORT=26658 E2E_TERRA_LCD_PORT=1318.
#
# Loaded by: scripts/qa/start-qa.sh (before docker compose), and by scripts/operator-ctl.sh when
# QA_SHARED_HOST=1 is set (after .env so these URLs win over stale defaults).
#
# Override any value by exporting before `make start-qa`, or add a repo-root `.env` with the same keys.

# Docker Compose host port mappings → bridge LocalTerra container (must match compose publish)
export E2E_TERRA_RPC_PORT="${E2E_TERRA_RPC_PORT:-26657}"
export E2E_TERRA_LCD_PORT="${E2E_TERRA_LCD_PORT:-1317}"
export E2E_TERRA_GRPC_PORT="${E2E_TERRA_GRPC_PORT:-9090}"
export E2E_TERRA_GRPC_WEB_PORT="${E2E_TERRA_GRPC_WEB_PORT:-9091}"

# URLs on the QA host (127.0.0.1). Use the same ports as E2E_TERRA_* above.
export TERRA_RPC_URL="${TERRA_RPC_URL:-http://127.0.0.1:${E2E_TERRA_RPC_PORT:-26657}}"
export TERRA_LCD_URL="${TERRA_LCD_URL:-http://127.0.0.1:${E2E_TERRA_LCD_PORT:-1317}}"

# Shared QA host: pin Terra URLs to the same ports docker compose published (see E2E_TERRA_* above).
if [ "${QA_SHARED_HOST:-}" = "1" ]; then
  export TERRA_RPC_URL="http://127.0.0.1:${E2E_TERRA_RPC_PORT:-26657}"
  export TERRA_LCD_URL="http://127.0.0.1:${E2E_TERRA_LCD_PORT:-1317}"
fi

# Operator HTTP API — must NOT use host port 9092 when E2E_TERRA_GRPC_PORT=9092 (Terra gRPC on host).
# Default 9194 (not 9094): 9094 is commonly used by IPFS cluster on dev machines and caused silent API failure.
export OPERATOR_API_PORT="${OPERATOR_API_PORT:-9194}"
export OPERATOR_API_URL="${OPERATOR_API_URL:-http://127.0.0.1:${OPERATOR_API_PORT}}"
export OPERATOR_API_BIND_ADDRESS="${OPERATOR_API_BIND_ADDRESS:-127.0.0.1}"
# Shared QA: migrate off legacy 9094 default from older .env copies (IPFS collision).
if [ "${QA_SHARED_HOST:-}" = "1" ] && [ "${OPERATOR_API_PORT}" = "9094" ]; then
  export OPERATOR_API_PORT=9194
  export OPERATOR_API_URL="http://127.0.0.1:${OPERATOR_API_PORT}"
fi

export EVM_RPC_URL="${EVM_RPC_URL:-http://127.0.0.1:8545}"
# Second Anvil (EVM↔EVM QA / e2e-infra anvil1)
export EVM1_RPC_URL="${EVM1_RPC_URL:-http://127.0.0.1:8546}"
# Operator requires these; match Anvil local + bridge V2 ids (see DeployLocal.s.sol)
export EVM_CHAIN_ID="${EVM_CHAIN_ID:-31337}"
export EVM_THIS_CHAIN_ID="${EVM_THIS_CHAIN_ID:-1}"
export TERRA_CHAIN_ID="${TERRA_CHAIN_ID:-localterra}"
export TERRA_THIS_CHAIN_ID="${TERRA_THIS_CHAIN_ID:-2}"
export FEE_RECIPIENT="${FEE_RECIPIENT:-0x70997970C51812dc3A010C7d01b50e0d17dc79C8}"
export DEFAULT_FEE_BPS="${DEFAULT_FEE_BPS:-30}"
export FINALITY_BLOCKS="${FINALITY_BLOCKS:-1}"
export POLL_INTERVAL_MS="${POLL_INTERVAL_MS:-1000}"
# Public Anvil dev key + LocalTerra test mnemonic (same as packages/operator/.env.example)
export EVM_PRIVATE_KEY="${EVM_PRIVATE_KEY:-0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80}"
if [ -z "${TERRA_MNEMONIC:-}" ]; then
  export TERRA_MNEMONIC='notice oak worry limit wrap speak medal online prefer cluster roof addict wrist behave treat actual wasp year salad speed social layer crew genius'
fi

export SOLANA_RPC_URL="${SOLANA_RPC_URL:-http://127.0.0.1:8899}"
export SOLANA_WS_URL="${SOLANA_WS_URL:-ws://127.0.0.1:8900}"
# Bridge program pubkey: NOT set here — must live in .deploy/local.env (make deploy / setup-bridge)
# so scp .deploy/local.env + write-frontend-env-local.sh can emit VITE_SOLANA_PROGRAM_ID.
# Align with frontend bridgeChains local Solana bytes4 id; operator defaults to 5 if unset
export SOLANA_V2_CHAIN_ID="${SOLANA_V2_CHAIN_ID:-5}"

# Postgres from docker-compose.yml (POSTGRES_USER/PASSWORD/DB). start-qa + operator-ctl source .env then this file;
# older .env.example used relayer/relayer — override so sqlx migrate and the operator hit the compose DB.
# Opt out: QA_USE_CUSTOM_DATABASE_URL=1
if [ "${QA_SHARED_HOST:-}" = "1" ] && [ "${QA_USE_CUSTOM_DATABASE_URL:-}" != "1" ]; then
  export DATABASE_URL="postgres://${POSTGRES_USER:-operator}:${POSTGRES_PASSWORD:-operator}@127.0.0.1:${POSTGRES_PORT:-5433}/${POSTGRES_DB:-operator}"
fi
