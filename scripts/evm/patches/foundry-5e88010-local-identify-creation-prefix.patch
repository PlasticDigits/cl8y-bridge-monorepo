+    /// Picks the best artifact by matching compiled creation bytecode as a prefix of `creation_code`
+    /// and validating trailing bytes against the ABI constructor when present.
+    fn identify_by_creation_prefix(
+        &self,
+        creation_code: &[u8],
+    ) -> Option<(&'a ArtifactId, &'a JsonAbi)> {
+        let mut best: Option<(&'a ArtifactId, &'a JsonAbi, usize)> = None;
+        for (id, contract) in self.known_contracts.iter() {
+            let Some(bytecode) = contract.bytecode_without_placeholders() else {
+                continue;
+            };
+            if bytecode.is_empty() || creation_code.len() < bytecode.len() {
+                continue;
+            }
+            let prefix = &creation_code[..bytecode.len()];
+            if bytecode_diff_score(bytecode.as_ref(), prefix) != 0.0 {
+                continue;
+            }
+            let ctor_args = &creation_code[bytecode.len()..];
+            match contract.abi.constructor() {
+                Some(constructor) => {
+                    if constructor.abi_decode_input(ctor_args).is_err() {
+                        continue;
+                    }
+                }
+                None => {
+                    if !ctor_args.is_empty() {
+                        continue;
+                    }
+                }
+            }
+            let n = bytecode.len();
+            if best.map_or(true, |(_, _, best_n)| n > best_n) {
+                best = Some((id, &contract.abi, n));
+            }
+        }
+        best.map(|(id, abi, _)| (id, abi))
+    }
+
